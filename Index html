<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#C9A84C">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="EVH">
<link rel="manifest" href="manifest.json">
<title>EVH &mdash; Exclusive Virgin Hair</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{--gold:#C9A84C;--gold-l:#E8D5A3;--black:#0D0D0D;--white:#FAFAF7;--s1:#161612;--s2:#1E1E19;--s3:#252520;--bd:rgba(201,168,76,0.15);--bd2:rgba(201,168,76,0.35);--mu:#888880;--mu2:#555550;--red:#E07070;--red-l:rgba(224,112,112,0.1);--grn:#6DBE8D;--grn-l:rgba(109,190,141,0.1);--blue:#6FA8DC;}
*{box-sizing:border-box;margin:0;padding:0}
html,body{background:var(--black);color:var(--white);font-family:'DM Sans',sans-serif;font-weight:300;min-height:100vh}

#branchScreen{position:fixed;inset:0;background:var(--black);z-index:1000;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:1.5rem;overflow-y:auto}
.brand-hero{text-align:center;margin-bottom:2.5rem}
.brand-logo{width:64px;height:64px;border:1.5px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;color:var(--gold);font-size:28px;margin:0 auto 1rem}
.brand-title{font-family:'Playfair Display',serif;font-size:clamp(1.3rem,5vw,1.9rem);font-weight:400;letter-spacing:-0.01em}
.brand-sub{font-size:10px;color:var(--mu);letter-spacing:.2em;text-transform:uppercase;margin-top:5px}
.select-hint{font-size:12px;color:var(--mu);margin-bottom:1.1rem;text-align:center}
.branch-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;width:100%;max-width:440px}
@media(min-width:460px){.branch-grid{grid-template-columns:repeat(3,1fr)}}
.branch-btn{background:var(--s1);border:1px solid var(--bd);border-radius:12px;padding:1.1rem .75rem;text-align:center;cursor:pointer;transition:all .2s}
.branch-btn:hover{background:rgba(201,168,76,.06);border-color:var(--gold)}
.branch-btn:hover .b-initial{background:rgba(201,168,76,.18);border-color:var(--gold)}
.b-initial{width:36px;height:36px;border-radius:50%;background:rgba(201,168,76,.09);border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;color:var(--gold);font-size:15px;margin:0 auto .65rem;transition:all .2s}
.branch-name{font-size:13px;font-weight:500}
.branch-city{font-size:10px;color:var(--mu);margin-top:2px;text-transform:uppercase;letter-spacing:.07em}
.hq-btn{width:100%;max-width:440px;margin-top:10px;background:var(--gold);color:var(--black);border:none;border-radius:12px;padding:13px;font-size:13px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:opacity .15s;letter-spacing:.02em}
.hq-btn:hover{opacity:.88}

#appScreen{display:none;flex-direction:column;min-height:100vh}
header{background:var(--s1);border-bottom:1px solid var(--bd);padding:.9rem 1.1rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.hdr-left{display:flex;align-items:center;gap:.75rem}
.hdr-logo{width:34px;height:34px;border:1px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;color:var(--gold);font-size:15px;flex-shrink:0}
.hdr-title{font-family:'Playfair Display',serif;font-size:.95rem;font-weight:400;letter-spacing:-0.01em}
.hdr-branch{font-size:10px;color:var(--gold);letter-spacing:.1em;text-transform:uppercase;margin-top:1px}
.sw-btn{background:transparent;border:1px solid var(--bd);border-radius:7px;padding:5px 11px;font-size:11px;color:var(--mu);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s}
.sw-btn:hover{border-color:var(--gold);color:var(--gold)}

.tabs{background:var(--s1);border-bottom:1px solid var(--bd);display:flex;overflow-x:auto;scrollbar-width:none}
.tabs::-webkit-scrollbar{display:none}
.tab{flex:1;min-width:60px;padding:.6rem .3rem .55rem;text-align:center;font-size:9px;color:var(--mu);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap;display:flex;flex-direction:column;align-items:center;gap:4px;letter-spacing:.05em;text-transform:uppercase}
.tab.active{color:var(--gold);border-bottom-color:var(--gold)}
.tab-panel{display:none}
.tab-panel.active{display:block}
main{max-width:680px;margin:0 auto;padding:1.1rem 1rem 5rem;flex:1}

.card{background:var(--s1);border:1px solid var(--bd);border-radius:12px;padding:1.1rem 1.2rem;margin-bottom:.85rem}
.card-title{font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--gold);margin-bottom:.9rem}
.hero{text-align:center;padding:1.25rem 0 1.75rem}
.hero h2{font-family:'Playfair Display',serif;font-size:clamp(1.4rem,5vw,2rem);font-weight:400;line-height:1.25;letter-spacing:-0.01em}
.hero h2 em{color:var(--gold);font-style:italic}
.hero p{color:var(--mu);font-size:13px;margin-top:.5rem;line-height:1.7}

.upload-zone{border:1.5px dashed var(--bd2);border-radius:10px;padding:1.75rem 1rem;text-align:center;cursor:pointer;transition:all .2s;position:relative;overflow:hidden;margin-bottom:.75rem}
.upload-zone:hover{background:var(--s2);border-color:var(--gold)}
.upload-zone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.upload-icon{width:46px;height:46px;margin:0 auto .8rem;border:1px solid var(--bd);border-radius:50%;display:flex;align-items:center;justify-content:center}
.upload-icon svg{width:22px;height:22px;stroke:var(--gold);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.upload-zone h3{font-size:14px;font-weight:400}
.upload-zone p{font-size:12px;color:var(--mu);margin-top:4px}

.img-grid-wrap{display:none;margin-bottom:.75rem}
.img-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:.55rem}
.img-bar-info{font-size:12px;color:var(--mu)}
.img-bar-info b{color:var(--white)}
.img-clear-btn{background:transparent;border:1px solid var(--bd);border-radius:6px;padding:3px 10px;font-size:11px;color:var(--mu);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s}
.img-clear-btn:hover{border-color:var(--red);color:var(--red)}
.img-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px}
@media(min-width:400px){.img-grid{grid-template-columns:repeat(4,1fr)}}
@media(min-width:520px){.img-grid{grid-template-columns:repeat(5,1fr)}}
.img-thumb{position:relative;aspect-ratio:1;border-radius:8px;overflow:hidden;border:1px solid var(--bd)}
.img-thumb img{width:100%;height:100%;object-fit:cover;display:block}
.img-thumb-del{position:absolute;top:3px;right:3px;width:20px;height:20px;background:rgba(0,0,0,.75);border:none;border-radius:50%;color:var(--white);font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;padding:0;transition:background .15s}
.img-thumb-del:hover{background:var(--red)}
.img-num{position:absolute;bottom:3px;left:3px;background:rgba(0,0,0,.65);border-radius:4px;padding:1px 5px;font-size:9px;color:var(--gold-l)}

.btn-g{width:100%;background:var(--gold);color:var(--black);border:none;border-radius:9px;padding:12px;font-size:14px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:opacity .15s}
.btn-g:hover{opacity:.88}
.btn-g:disabled{opacity:.3;cursor:not-allowed}
.btn-o{width:100%;background:transparent;border:1px solid var(--bd);border-radius:9px;padding:11px;font-size:14px;color:var(--gold);font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .15s}
.btn-o:hover{border-color:var(--gold);background:rgba(201,168,76,.05)}
.btn-row{display:flex;gap:8px;margin-top:.75rem}
.btn-row>*{flex:1}

.loader{display:none;text-align:center;padding:1.25rem}
.ring{width:28px;height:28px;border:2px solid rgba(201,168,76,.18);border-top-color:var(--gold);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto .6rem}
@keyframes spin{to{transform:rotate(360deg)}}
.loader p{font-size:13px;color:var(--mu)}

.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-bottom:.85rem}
@media(max-width:380px){.stats-grid{grid-template-columns:repeat(2,1fr)}}
.stat{background:var(--s2);border-radius:8px;padding:.65rem .75rem}
.stat.hi{background:rgba(201,168,76,.07);border:1px solid rgba(201,168,76,.2)}
.stat.danger{background:rgba(224,112,112,.07);border:1px solid rgba(224,112,112,.2)}
.stat-l{font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--mu);margin-bottom:4px}
.stat-v{font-size:1.1rem;font-weight:500}
.stat.hi .stat-v{color:var(--gold)}
.stat.danger .stat-v{color:var(--red)}

.tbl-wrap{overflow-x:auto;border:1px solid var(--bd);border-radius:9px;margin-bottom:.85rem}
table{width:100%;border-collapse:collapse;font-size:12px;min-width:480px}
thead tr{background:var(--s2)}
th{padding:8px 10px;text-align:left;color:var(--mu);font-weight:400;font-size:10px;text-transform:uppercase;letter-spacing:.07em;border-bottom:1px solid var(--bd);white-space:nowrap}
td{padding:8px 10px;border-bottom:1px solid rgba(255,255,255,.04);vertical-align:top}
tr:last-child td{border-bottom:none}
tr.row-total td{background:rgba(201,168,76,.06);color:var(--gold-l);font-weight:500}
.exp-item{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:13px}
.exp-item:last-child{border-bottom:none}
.exp-item .lbl{color:var(--mu)}
.exp-item .amt{color:var(--red);font-weight:500}
.exp-item.ttl{border-top:1px solid var(--bd);margin-top:4px;padding-top:10px}
.exp-item.ttl .lbl{color:var(--white)}

.sep{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--gold);margin:1rem 0 .6rem;display:flex;align-items:center;gap:8px}
.sep::after{content:'';flex:1;height:1px;background:var(--bd)}
.results-sec{display:none}

.branch-league{display:flex;flex-direction:column;gap:8px}
.branch-row{background:var(--s2);border:1px solid var(--bd);border-radius:9px;padding:.8rem 1rem;display:flex;align-items:center;gap:10px}
.branch-row.top{border-color:var(--gold);background:rgba(201,168,76,.07)}
.branch-rank{font-size:18px;width:28px;flex-shrink:0;text-align:center}
.branch-info{flex:1}
.branch-info-name{font-size:14px;font-weight:500}
.branch-info-city{font-size:11px;color:var(--mu)}
.bar-track{flex:1;background:var(--s3);border-radius:4px;height:5px;overflow:hidden;margin-top:6px}
.bar-fill{height:100%;border-radius:4px;background:var(--gold)}
.branch-rev{text-align:right;flex-shrink:0}
.branch-rev-val{font-size:15px;font-weight:500;color:var(--gold)}
.branch-rev-lbl{font-size:10px;color:var(--mu)}
.wk-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:.9rem}
@media(min-width:480px){.wk-grid{grid-template-columns:repeat(4,1fr)}}
.wk-stat{background:var(--s2);border-radius:8px;padding:.7rem}
.wk-stat-l{font-size:10px;color:var(--mu);text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px}
.wk-stat-v{font-size:1.1rem;font-weight:500;color:var(--gold)}
.c-row{display:flex;align-items:center;gap:7px;margin-bottom:5px}
.c-row .lbl{width:72px;color:var(--mu);text-align:right;flex-shrink:0;font-size:11px}
.c-track{flex:1;background:var(--s2);border-radius:4px;height:12px;overflow:hidden}
.c-fill{height:100%;border-radius:4px}
.c-fill.cash{background:var(--grn)}
.c-fill.swipe{background:var(--gold)}
.c-fill.eft{background:var(--blue)}
.c-row .val{width:54px;color:var(--white);font-size:11px;flex-shrink:0}

.rec-list{display:flex;flex-direction:column;gap:9px;margin-bottom:.9rem}
.rec-card{background:var(--s2);border:1px solid var(--bd);border-radius:10px;padding:.85rem}
.rec-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;gap:6px}
.rec-name-inp{background:transparent;border:none;border-bottom:1px solid var(--bd);color:var(--white);font-size:14px;font-family:'DM Sans',sans-serif;padding:3px 0;flex:1;outline:none;min-width:0}
.rec-name-inp::placeholder{color:var(--mu)}
.rec-name-inp:focus{border-bottom-color:var(--gold)}
.rec-role-sel{background:var(--s3);border:1px solid var(--bd);border-radius:6px;padding:3px 7px;color:var(--gold);font-size:10px;font-family:'DM Sans',sans-serif;flex-shrink:0}
.rm-btn{background:transparent;border:none;color:var(--mu2);font-size:18px;cursor:pointer;line-height:1;flex-shrink:0;padding:0 2px}
.rm-btn:hover{color:var(--red)}
.f-row{display:grid;grid-template-columns:1fr;gap:8px}
.f{display:flex;flex-direction:column;gap:3px}
.f label{font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--mu)}
.f input{background:var(--s1);border:1px solid var(--bd);border-radius:7px;padding:8px 9px;color:var(--white);font-size:13px;font-family:'DM Sans',sans-serif;outline:none}
.f input:focus{border-color:var(--gold)}
.f input::placeholder{color:var(--mu2)}
.add-btn{width:100%;background:transparent;border:1px dashed rgba(201,168,76,.28);border-radius:9px;padding:9px;color:var(--mu);font-size:13px;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .15s;margin-bottom:.85rem}
.add-btn:hover{border-color:var(--gold);color:var(--gold)}

.feature-list{display:flex;flex-direction:column}
.feature-item{font-size:13px;color:var(--mu);line-height:1.6;padding:.28rem 0 .28rem 1rem;position:relative}
.feature-item::before{content:'';position:absolute;left:0;top:.62rem;width:4px;height:4px;border-radius:50%;background:var(--gold);opacity:.5}

.rep-box{background:var(--s2);border-radius:9px;padding:.9rem;font-size:13px;color:var(--mu);line-height:1.8;white-space:pre-wrap;display:none;margin:.7rem 0;border:1px solid var(--bd);max-height:300px;overflow-y:auto}
.sl{font-size:12px;padding:6px 10px;border-radius:7px;margin-top:5px}
.sl.ok{background:var(--grn-l);color:var(--grn)}
.sl.err{background:var(--red-l);color:var(--red)}
.sl.info{background:rgba(111,168,220,.1);color:var(--blue)}

.sf{display:flex;flex-direction:column;gap:4px;margin-bottom:.85rem}
.sf label{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--mu)}
.sf input{background:var(--s2);border:1px solid var(--bd);border-radius:8px;padding:10px 11px;color:var(--white);font-size:13px;font-family:'DM Sans',sans-serif;outline:none}
.sf input:focus{border-color:var(--gold)}
.sf input::placeholder{color:var(--mu2)}
.hint{font-size:11px;color:var(--mu);line-height:1.6;margin-bottom:.75rem}
.hint a{color:var(--gold);text-decoration:none}

.badge{display:inline-block;font-size:10px;padding:2px 7px;border-radius:4px;font-weight:500;text-transform:uppercase;letter-spacing:.06em}
.badge.cash{background:rgba(109,190,141,.15);color:var(--grn)}
.badge.swipe{background:rgba(201,168,76,.15);color:var(--gold)}
.badge.eft{background:rgba(111,168,220,.15);color:var(--blue)}
.badge.mixed{background:rgba(255,255,255,.08);color:var(--mu)}

.toast{position:fixed;bottom:1.25rem;left:50%;transform:translateX(-50%) translateY(20px);background:var(--gold);color:var(--black);padding:8px 18px;border-radius:50px;font-size:13px;font-weight:500;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap;z-index:9999}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
textarea{width:100%;min-height:80px;background:var(--s2);border:1px solid var(--bd);border-radius:8px;padding:9px 11px;color:var(--white);font-size:13px;font-family:'DM Sans',sans-serif;resize:vertical;outline:none}
textarea:focus{border-color:var(--gold)}
textarea::placeholder{color:var(--mu2)}
footer{text-align:center;padding:1.5rem 1rem 1rem;font-size:10px;color:var(--mu2);letter-spacing:.1em;border-top:1px solid var(--bd);margin-top:2rem}

/* ── Management gate ── */
#mgmtGate{position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:3000;align-items:center;justify-content:center;padding:1.5rem;backdrop-filter:blur(6px)}
.gate-box{background:var(--s1);border:1px solid var(--bd);border-radius:16px;padding:2rem 1.5rem;width:100%;max-width:340px;text-align:center}
.gate-logo{width:52px;height:52px;border:1.5px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;color:var(--gold);font-size:22px;margin:0 auto 1.1rem}
.gate-title{font-family:'Playfair Display',serif;font-size:1.25rem;margin-bottom:.3rem}
.gate-sub{font-size:12px;color:var(--mu);margin-bottom:1.4rem;line-height:1.65}
.gate-inp{width:100%;background:var(--s2);border:1px solid var(--bd);border-radius:9px;padding:11px 14px;color:var(--white);font-size:16px;font-family:'DM Sans',sans-serif;outline:none;text-align:center;letter-spacing:.18em;margin-bottom:.75rem}
.gate-inp:focus{border-color:var(--gold)}
.gate-err{font-size:12px;color:var(--red);margin-bottom:.6rem;display:none}

/* ── CFO sub-tabs ── */
.sub-tabs{display:flex;gap:6px;overflow-x:auto;scrollbar-width:none;padding-bottom:2px;margin-bottom:1rem}
.sub-tabs::-webkit-scrollbar{display:none}
.sub-tab{background:var(--s2);border:1px solid var(--bd);border-radius:7px;padding:6px 12px;font-size:11px;color:var(--mu);cursor:pointer;white-space:nowrap;transition:all .15s;flex-shrink:0}
.sub-tab.active{background:rgba(201,168,76,.1);border-color:var(--gold);color:var(--gold)}
.sub-panel{display:none}
.sub-panel.active{display:block}

/* ── Red flags ── */
.flag-card{background:var(--s2);border-radius:10px;padding:.85rem;margin-bottom:.6rem;border-left:3px solid var(--red)}
.flag-card.warn{border-left-color:#E0A840}
.flag-card.ok{border-left-color:var(--grn)}
.flag-hdr{display:flex;align-items:center;gap:7px;margin-bottom:5px}
.flag-badge{font-size:9px;font-weight:600;padding:2px 7px;border-radius:4px;text-transform:uppercase;letter-spacing:.08em}
.flag-badge.red{background:var(--red-l);color:var(--red)}
.flag-badge.warn{background:rgba(224,168,64,.12);color:#E0A840}
.flag-badge.ok{background:var(--grn-l);color:var(--grn)}
.flag-branch{font-size:10px;color:var(--mu)}
.flag-title{font-size:13px;font-weight:500;margin-bottom:3px}
.flag-body{font-size:12px;color:var(--mu);line-height:1.6}

/* ── Chart of accounts ── */
.coa-section{margin-bottom:1rem}
.coa-hdr{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--gold);padding:.4rem .75rem;background:rgba(201,168,76,.05);border-radius:6px;border-left:2px solid var(--gold);margin-bottom:.4rem}
.coa-row{display:flex;align-items:center;padding:7px .75rem;border-bottom:1px solid rgba(255,255,255,.04);font-size:13px}
.coa-row:last-child{border-bottom:none}
.acc-num{font-size:10px;color:var(--mu);width:38px;flex-shrink:0;font-family:monospace;letter-spacing:.04em}
.acc-name{flex:1;color:var(--mu)}
.acc-val{font-weight:500;text-align:right;min-width:90px}
.coa-row.subtot{background:rgba(255,255,255,.03)}
.coa-row.subtot .acc-name{color:var(--white);font-weight:500}
.coa-row.net-row{background:rgba(109,190,141,.06);border-radius:8px;padding:10px .75rem;border:1px solid rgba(109,190,141,.2);margin-top:8px}
.coa-row.net-row .acc-name{color:var(--grn);font-weight:500}
.coa-row.net-row .acc-val{color:var(--grn);font-size:1.05rem}

/* ── Stock reconciliation ── */
.stk-card{background:var(--s2);border:1px solid var(--bd);border-radius:10px;padding:.85rem 1rem;margin-bottom:.6rem}
.stk-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:.65rem}
.stk-name{font-size:14px;font-weight:500}
.stk-badge{font-size:9px;font-weight:600;padding:2px 8px;border-radius:4px;text-transform:uppercase;letter-spacing:.07em}
.stk-badge.ok{background:var(--grn-l);color:var(--grn)}
.stk-badge.warn{background:rgba(224,168,64,.12);color:#E0A840}
.stk-badge.red{background:var(--red-l);color:var(--red)}
.stk-items{display:grid;grid-template-columns:repeat(3,1fr);gap:5px}
.stk-item{text-align:center;background:rgba(255,255,255,.03);border-radius:6px;padding:.5rem .3rem}
.stk-item-l{font-size:9px;color:var(--mu);text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.stk-item-v{font-size:13px;font-weight:500}

/* ── Cash-up ── */
.cu-variance-box{border-radius:8px;padding:.75rem 1rem;margin:.5rem 0}
.cu-variance-box.ok{background:var(--grn-l);border:1px solid rgba(109,190,141,.2);color:var(--grn)}
.cu-variance-box.warn{background:rgba(224,168,64,.1);border:1px solid rgba(224,168,64,.2);color:#E0A840}
.cu-variance-box.bad{background:var(--red-l);border:1px solid rgba(224,112,112,.2);color:var(--red)}
.cu-variance-val{font-size:1.3rem;font-weight:500;margin-bottom:3px}
.cu-variance-label{font-size:12px;opacity:.85}
.cu-hist-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:13px}
.cu-hist-row:last-child{border-bottom:none}
.cu-hist-date{color:var(--mu);font-size:12px}
.cu-hist-actual{color:var(--white)}
.cu-hist-var{font-weight:500;font-size:12px}
/* ── KPI scorecard ── */
.kpi-table{min-width:0!important;width:100%}
.kpi-val{font-size:13px;font-weight:500;color:var(--gold)}
.rag{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:3px;vertical-align:middle}
.rag.green{background:var(--grn)}
.rag.amber{background:#E0A840}
.rag.red{background:var(--red)}
/* ── Analysis success card ── */
.asc{background:rgba(109,190,141,.08);border:1px solid rgba(109,190,141,.3);border-radius:10px;padding:.85rem 1rem;margin-bottom:.75rem;display:flex;align-items:center;gap:10px}
.asc-icon{width:30px;height:30px;border-radius:50%;background:var(--grn);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;flex-shrink:0;color:#0D0D0D}
.asc-title{font-size:13px;font-weight:500;color:var(--grn)}
.asc-sub{font-size:11px;color:var(--mu);margin-top:2px}
.asc-lnk{font-size:11px;color:var(--gold);cursor:pointer;white-space:nowrap;flex-shrink:0;text-decoration:none;font-weight:500}
/* ── Analysis result modal ── */
.anlz-overlay{position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:900;display:flex;align-items:center;justify-content:center;padding:1.25rem;animation:fadeIn .18s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.anlz-card{background:var(--s2);border-radius:16px;padding:1.75rem 1.5rem 1.5rem;max-width:340px;width:100%;text-align:center;animation:slideUp .22s ease;box-shadow:0 12px 40px rgba(0,0,0,.6);position:relative}
@keyframes slideUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
.anlz-card.success{border:1.5px solid rgba(109,190,141,.4)}
.anlz-card.failure{border:1.5px solid rgba(224,112,112,.4)}
.anlz-icon{width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:700;margin:0 auto 1rem}
.anlz-card.success .anlz-icon{background:rgba(109,190,141,.15);color:var(--grn);border:1.5px solid rgba(109,190,141,.35)}
.anlz-card.failure .anlz-icon{background:rgba(224,112,112,.12);color:var(--red);border:1.5px solid rgba(224,112,112,.3)}
.anlz-title{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:600;margin-bottom:.45rem}
.anlz-card.success .anlz-title{color:var(--grn)}
.anlz-card.failure .anlz-title{color:var(--red)}
.anlz-sub{font-size:12px;color:var(--mu);line-height:1.6;margin-bottom:1.25rem}
.anlz-actions{display:flex;gap:.6rem;justify-content:center;flex-wrap:wrap}
.anlz-btn{border:none;border-radius:8px;padding:.55rem 1.1rem;font-size:12px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:opacity .15s}
.anlz-btn:hover{opacity:.82}
.anlz-btn.primary{background:var(--gold);color:var(--black)}
.anlz-btn.ghost{background:transparent;border:1px solid var(--bd2);color:var(--mu)}
.anlz-close{position:absolute;top:.75rem;right:.85rem;background:transparent;border:none;color:var(--mu);font-size:18px;cursor:pointer;line-height:1;padding:2px 4px}
.anlz-close:hover{color:var(--white)}
/* ── Sheet preview ── */
.sheet-wrap{overflow-x:auto;border-radius:6px;overflow:hidden;margin-bottom:.5rem;box-shadow:0 2px 8px rgba(0,0,0,.35)}
.sheet-tbl{border-collapse:collapse;width:100%;font-size:11px;min-width:540px;background:#fff;color:#222;font-family:Arial,sans-serif}
.sheet-tbl thead th{background:#1558d6;color:#fff;font-weight:600;padding:6px 9px;border:1px solid #1a6bff;text-align:left;white-space:nowrap;font-size:10px;letter-spacing:.04em}
.sheet-tbl td{padding:4px 9px;border:1px solid #e0e0e0;white-space:nowrap;max-width:160px;overflow:hidden;text-overflow:ellipsis}
.sheet-tbl tbody tr:nth-child(even) td{background:#f8f9fa}
.sheet-tbl tr.st-total td{background:#e8f0fe;font-weight:600;color:#1558d6;border-color:#c4d4f5}
.sheet-tbl tr.st-exp td{background:#fce8e6;color:#c5221f;border-color:#f5c6c2}
/* ── Projection card ── */
.proj-card{background:rgba(111,168,220,.06);border:1px solid rgba(111,168,220,.18);border-radius:9px;padding:.85rem 1rem;margin-top:.6rem}
.proj-title{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--blue);margin-bottom:.6rem}
.proj-row{display:flex;justify-content:space-between;align-items:center;font-size:13px;padding:3px 0}
.proj-row .lbl{color:var(--mu)}
.proj-row .val{font-weight:500}
</style>
</head>
