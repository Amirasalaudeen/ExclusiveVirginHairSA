/* ── Analysis ── */
const API_HEADERS=key=>({'Content-Type':'application/json','x-api-key':key,'anthropic-version':'2023-06-01','anthropic-dangerous-allow-browser':'true'});

async function analyse(){
  const key=getKey();
  if(!key){toast('Add your API key in Settings first');switchTab('settings');return;}
  if(!imgFiles.length)return;
  const btn=document.getElementById('anlBtn');
  btn.disabled=true;
  document.getElementById('anlLoader').style.display='block';
  document.getElementById('resSec').style.display='none';
  const lt=document.getElementById('ldTxt');
  const bName=curBranch?curBranch.name:'EVH';
  const results=[];let errors=0;

  for(let i=0;i<imgFiles.length;i++){
    lt.textContent=imgFiles.length>1?`Analysing image ${i+1} of ${imgFiles.length}...`:'Reading your handwriting...';
    const f=imgFiles[i];
    try{
      const res=await fetch('https://api.anthropic.com/v1/messages',{
        method:'POST',headers:API_HEADERS(key),
        body:JSON.stringify({
          model:'claude-opus-4-7',max_tokens:2000,
          system:`You extract transaction data from a South African hair salon called ${bName}. Return only valid JSON.`,
          messages:[{role:'user',content:[
            {type:'image',source:{type:'base64',media_type:f.mime,data:f.b64}},
            {type:'text',text:`Extract all transactions from this handwritten salon book. Return ONLY valid JSON:\n{"date":"DD Mon YYYY","transactions":[{"time":"HH:MM or empty","service":"product/service","client_name":"or empty","client_phone":"or empty","payment_method":"Cash|Swipe|EFT|Swipe/PayFlex|Swipe/PayJustNow|Cash/Swipe|PayFlex|PayJustNow","cash":0,"swipe":0,"eft_payflex_pjn":0,"total":0,"notes":"or empty"}],"expenses":[{"description":"item","amount":0}],"daily_total":{"cash":0,"swipe":0,"eft_payflex_pjn":0,"gross":0,"total_expenses":0,"cash_in_hand":0}}`}
          ]}]
        })
      });
      const data=await res.json();
      if(data.error)throw new Error(data.error.message);
      const raw=data.content.map(b=>b.text||'').join('');
      results.push(JSON.parse(raw.replace(/```json|```/g,'').trim()));
    }catch(err){errors++;console.error('Image '+(i+1)+':',err);}
  }

  document.getElementById('anlLoader').style.display='none';
  btn.disabled=false;
  if(!results.length){
    setSt('sheetSt','Could not read any images. Check your API key and image quality.','err');
    showAnalysisModal('failure',
      'Analysis failed',
      'No data could be extracted from the uploaded images. Check your API key and try again with clearer images.',
      [{label:'Go to Settings',primary:true,fn:()=>switchTab('settings')},{label:'Dismiss',primary:false}]
    );
    return;
  }
  parsed=results.length===1?results[0]:mergeResults(results);
  renderResults(parsed);
  if(errors)showAnalysisModal('failure',
    'Partial analysis',
    `${errors} image${errors>1?'s':''} could not be read. Results below are from the remaining images — check for missing transactions.`,
    [{label:'View results',primary:true,fn:()=>document.getElementById('resSec').scrollIntoView({behavior:'smooth'})},{label:'Dismiss',primary:false}]
  );
}

function mergeResults(results){
  const m={
    date:results.map(r=>r.date||'').filter(Boolean).join(', '),
    transactions:[],expenses:[],
    daily_total:{cash:0,swipe:0,eft_payflex_pjn:0,gross:0,total_expenses:0,cash_in_hand:0}
  };
  results.forEach(r=>{
    (r.transactions||[]).forEach(t=>m.transactions.push(t));
    (r.expenses||[]).forEach(e=>m.expenses.push(e));
    const dt=r.daily_total||{};
    m.daily_total.cash+=(dt.cash||0);
    m.daily_total.swipe+=(dt.swipe||0);
    m.daily_total.eft_payflex_pjn+=(dt.eft_payflex_pjn||0);
    m.daily_total.gross+=(dt.gross||0);
    m.daily_total.total_expenses+=(dt.total_expenses||0);
    m.daily_total.cash_in_hand+=(dt.cash_in_hand||0);
  });
  return m;
}

/* ── Results display ── */
function pBadge(m){
  const ml=(m||'').toLowerCase();
  if(ml==='cash')return'<span class="badge cash">Cash</span>';
  if(ml.includes('payflex'))return'<span class="badge eft">PayFlex</span>';
  if(ml.includes('payjustnow'))return'<span class="badge eft">PJN</span>';
  if(ml.includes('eft'))return'<span class="badge eft">EFT</span>';
  if(ml.includes('swipe'))return'<span class="badge swipe">Swipe</span>';
  return`<span class="badge mixed">${m||'—'}</span>`;
}
function R(n){return n&&n>0?'R'+Number(n).toFixed(0):'—';}
function rc(n){return n&&n>0?Number(n).toFixed(0):'';}
function setSt(id,msg,type){document.getElementById(id).innerHTML=`<div class="sl ${type}">${msg}</div>`;}

function renderResults(d){
  const dt=d.daily_total;
  document.getElementById('resDate').textContent=(curBranch?curBranch.name+' — ':'')+d.date;
