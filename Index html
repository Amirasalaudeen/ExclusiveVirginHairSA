    <div class="stat"><div class="stat-l">Cash</div><div class="stat-v">${R(dt.cash)}</div></div>
    <div class="stat"><div class="stat-l">Swipe</div><div class="stat-v">${R(dt.swipe)}</div></div>
    <div class="stat"><div class="stat-l">EFT / PayFlex / PJN</div><div class="stat-v">${R(dt.eft_payflex_pjn)}</div></div>
    <div class="stat danger"><div class="stat-l">Expenses</div><div class="stat-v">${R(dt.total_expenses)}</div></div>
    <div class="stat hi"><div class="stat-l">Cash in hand</div><div class="stat-v">${R(dt.cash_in_hand)}</div></div>`;
