    const d=BD[b.id];
    if(!d||d.gross===0)return`<tr><td style="font-size:13px;font-weight:500;padding:8px 10px">${b.name}</td><td colspan="4" style="color:var(--mu);font-size:11px;padding:8px 10px">No data this period</td></tr>`;
    const avg=Math.round(d.gross/d.days);
    const expR=Math.round(d.expenses/d.gross*100);
    const netM=Math.round((d.gross-d.expenses)/d.gross*100);
    const rAvg=avg>=target?'green':avg>=target*0.7?'amber':'red';
