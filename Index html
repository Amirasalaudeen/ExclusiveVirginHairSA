      <div class="coa-row subtot"><span class="acc-num"></span><span class="acc-name">Total Expenses</span><span class="acc-val" style="color:var(--red)">${Rf(tE)}</span></div>
    </div>
    <div class="coa-row net-row"><span class="acc-num">NET</span><span class="acc-name">Net Operating Profit</span><span class="acc-val">${Rf(net)}</span></div>
    <p style="font-size:11px;color:var(--mu);margin-top:1rem;line-height:1.65;padding:0 .25rem">Revenue split is estimated from typical EVH service mix. Tag transactions by service type monthly to improve accuracy.</p>`;
}

function computeFlags(){
  const flags=[];
  const tG=Object.values(BD).reduce((a,d)=>a+d.gross,0);
  const tE=Object.values(BD).reduce((a,d)=>a+d.expenses,0);
  if(tE/tG>0.25)flags.push({sev:'red',branch:'Group',title:`Group expense ratio ${Math.round(tE/tG*100)}%`,body:`Total expenses R${tE.toLocaleString()} against revenue R${tG.toLocaleString()}. Above the 25% group threshold — cost review recommended.`});

  BRANCHES.forEach(b=>{
    const d=BD[b.id];
    if(!d||d.gross===0){
      flags.push({sev:'red',branch:b.name,title:'No revenue recorded',body:`${b.name} shows R0 for this period. Branch may not be submitting daily reports.`});
      return;
    }
    const expR=d.expenses/d.gross;
    if(expR>0.30)flags.push({sev:'red',branch:b.name,title:`Expenses ${Math.round(expR*100)}% of revenue`,body:`R${d.expenses.toLocaleString()} expenses vs R${d.gross.toLocaleString()} revenue. Well above 25% threshold.`});
    else if(expR>0.20)flags.push({sev:'warn',branch:b.name,title:`Expenses ${Math.round(expR*100)}% of revenue`,body:`R${d.expenses.toLocaleString()} expenses approaching the 25% warning threshold.`});
    if(d.days<12)flags.push({sev:'warn',branch:b.name,title:`Only ${d.days} trading days`,body:`Expected 18–22 days in April. ${22-d.days} days of data may be missing or unreported.`});
    const avg=d.gross/d.days;
    if(d.bestAmt>avg*3.2)flags.push({sev:'warn',branch:b.name,title:`Best day is ${Math.round(d.bestAmt/avg)}× the daily average`,body:`Best day R${d.bestAmt.toLocaleString()} vs avg R${Math.round(avg).toLocaleString()}. Verify this is not a duplicate entry.`});
    if(d.cash===0&&d.gross>40000)flags.push({sev:'warn',branch:b.name,title:'Zero cash on high-revenue branch',body:`R0 cash on R${d.gross.toLocaleString()} revenue. Confirm all cash sales are being recorded.`});
  });
  // Low daily average vs configurable target
  const dailyT=parseFloat(localStorage.getItem('evh_daily_target')||'5000');
  BRANCHES.forEach(b=>{
    const d=BD[b.id];
    if(!d||d.gross===0||d.days<5)return;
    const avg=d.gross/d.days;
    if(avg<dailyT*0.65)flags.push({sev:'warn',branch:b.name,title:`Daily average R${Math.round(avg).toLocaleString()} — below target`,body:`${b.name} averaging R${Math.round(avg).toLocaleString()}/day vs R${dailyT.toLocaleString()} target. Potential April revenue gap: R${Math.round((dailyT-avg)*d.days).toLocaleString()}.`});
  });
  // Cash shortage patterns from cash-up history
  BRANCHES.forEach(b=>{
    const hist=JSON.parse(localStorage.getItem('evh_cu_'+b.id)||'[]');
    const shortages=hist.slice(0,10).filter(r=>r.variance<-50);
    if(shortages.length>=2)flags.push({sev:'red',branch:b.name,title:`${shortages.length} unresolved cash shortages`,body:`${shortages.length} recent end-of-day cash-ups show shortfalls >R50. Total unaccounted: R${Math.abs(shortages.reduce((a,r)=>a+r.variance,0)).toFixed(0)}. Investigate immediately.`});
  });
  return flags;
}

function genFlagHTML(flags){
  if(!flags.length)return`<div class="flag-card ok"><div class="flag-hdr"><span class="flag-badge ok">All Clear</span></div><div class="flag-title">No anomalies detected</div><p class="flag-body">All branches are within normal operating parameters for this period.</p></div>`;
  return flags.map(f=>`
    <div class="flag-card${f.sev==='warn'?' warn':''}">
      <div class="flag-hdr">
        <span class="flag-badge ${f.sev==='warn'?'warn':'red'}">${f.sev==='warn'?'Warning':'Critical'}</span>
        <span class="flag-branch">${f.branch}</span>
      </div>
      <div class="flag-title">${f.title}</div>
      <p class="flag-body">${f.body}</p>
    </div>`).join('');
}

function genStockHTML(){
  const active=BRANCHES.map(b=>({b,d:BD[b.id]})).filter(({d})=>d&&d.gross>0);
  const rows=active.map(({b,d})=>{
    const estCOGS=Math.round(d.gross*0.18);
    const estUnits=Math.round(d.gross/420);
    const variance=d.expenses>0?Math.abs(d.expenses-estCOGS)/estCOGS:1;
    const st=variance>0.5?'red':variance>0.25?'warn':'ok';
    const stLabel=st==='red'?'Review':st==='warn'?'Monitor':'On Track';
    const expR=d.expenses/d.gross;
    return`
      <div class="stk-card">
        <div class="stk-hdr">
          <span class="stk-name">${b.name}</span>
          <span class="stk-badge ${st}">${stLabel}</span>
        </div>
        <div class="stk-items">
          <div class="stk-item"><div class="stk-item-l">Revenue</div><div class="stk-item-v" style="color:var(--gold)">R${(d.gross/1000).toFixed(0)}k</div></div>
          <div class="stk-item"><div class="stk-item-l">Est. Units</div><div class="stk-item-v">${estUnits}</div></div>
          <div class="stk-item"><div class="stk-item-l">Est. COGS</div><div class="stk-item-v" style="color:var(--mu)">R${(estCOGS/1000).toFixed(1)}k</div></div>
          <div class="stk-item"><div class="stk-item-l">Actual Exp</div><div class="stk-item-v" style="color:${expR>0.25?'var(--red)':'inherit'}">R${(d.expenses/1000).toFixed(1)}k</div></div>
          <div class="stk-item"><div class="stk-item-l">Exp %</div><div class="stk-item-v" style="color:${expR>0.25?'var(--red)':'var(--grn)'}">${Math.round(expR*100)}%</div></div>
          <div class="stk-item"><div class="stk-item-l">Days</div><div class="stk-item-v">${d.days}</div></div>
        </div>
      </div>`;
  }).join('');
  return`
    <div class="card" style="padding:.85rem;margin-bottom:.75rem">
      <p style="font-size:12px;color:var(--mu);line-height:1.7">Compares estimated COGS (18% of revenue) against reported expenses. Flag raised when actual expenses deviate more than 50% from estimate.</p>
    </div>
    ${rows}`;
}

/* ── WhatsApp ── */
function sendWhatsApp(){
  if(!parsed)return;
  const dt=parsed.daily_total;
  const branch=curBranch?curBranch.name:'EVH';
  const msg=`*EVH ${branch} — ${parsed.date}*\n\nRevenue: *R${Number(dt.gross).toFixed(0)}*\nCash: R${Number(dt.cash).toFixed(0)}  |  Swipe: R${Number(dt.swipe).toFixed(0)}  |  EFT: R${Number(dt.eft_payflex_pjn).toFixed(0)}\nExpenses: R${Number(dt.total_expenses).toFixed(0)}\nCash in Hand: R${Number(dt.cash_in_hand).toFixed(0)}\nTransactions: ${(parsed.transactions||[]).length}\n\n_EVH Transaction Intelligence_`;
  window.open('https://wa.me/?text='+encodeURIComponent(msg),'_blank');
  toast('Opening WhatsApp...');
}

/* ── Cash-up ── */
function buildCashUpTab(){
  if(!curBranch)return;
  document.getElementById('cuBranchLabel').textContent=curBranch.name;
  const expEl=document.getElementById('cuExpected');
  if(parsed&&parsed.daily_total&&parsed.daily_total.cash){
    expEl.value=parsed.daily_total.cash;
  }else{
    expEl.value='';
  }
  document.getElementById('cuActual').value='';
  document.getElementById('cuVariance').innerHTML='';
  document.getElementById('cuSt').innerHTML='';
  loadCashUpHistory();
  const d=BD[curBranch.id];
  const projEl=document.getElementById('cuProjection');
  if(d&&d.gross>0&&d.days>0&&projEl){
    const avg=Math.round(d.gross/d.days);
    const daysRemain=Math.max(0,30-d.days);
    const projected=Math.round(d.gross+avg*daysRemain);
    projEl.innerHTML=`<div class="proj-card"><div class="proj-title">April 2026 projection</div><div class="proj-row"><span class="lbl">Avg/day so far</span><span class="val">R${avg.toLocaleString()}</span></div><div class="proj-row"><span class="lbl">Days remaining</span><span class="val">${daysRemain}</span></div><div class="proj-row"><span class="lbl">Projected month total</span><span class="val" style="color:var(--gold)">R${projected.toLocaleString()}</span></div></div>`;
  }else if(projEl){projEl.innerHTML='';}
}

function updateVariance(){
  const exp=parseFloat(document.getElementById('cuExpected').value)||0;
  const act=parseFloat(document.getElementById('cuActual').value)||0;
  const el=document.getElementById('cuVariance');
  if(!document.getElementById('cuActual').value){el.innerHTML='';return;}
  const v=act-exp;
  const abs=Math.abs(v);
  const ok=abs<=50;
  const over=v>50;
  const cls=ok?'ok':over?'warn':'bad';
  const msg=ok?'Balanced — within R50':(over?`Over by R${abs.toFixed(0)} — double-check entries`:`Short by R${abs.toFixed(0)} — investigate immediately`);
  el.innerHTML=`<div class="cu-variance-box ${cls}"><div class="cu-variance-val">${v>=0?'+':'−'}R${abs.toFixed(0)}</div><div class="cu-variance-label">${msg}</div></div>`;
}

function saveCashUp(){
  if(!curBranch)return;
  const exp=parseFloat(document.getElementById('cuExpected').value)||0;
  const act=parseFloat(document.getElementById('cuActual').value)||0;
  if(!act){toast('Enter actual cash amount first');return;}
  const date=parsed?parsed.date:new Date().toLocaleDateString('en-ZA',{day:'numeric',month:'short',year:'numeric'});
  const key='evh_cu_'+curBranch.id;
  const hist=JSON.parse(localStorage.getItem(key)||'[]');
  hist.unshift({date,expected:exp,actual:act,variance:act-exp,ts:Date.now()});
  hist.splice(60);
  localStorage.setItem(key,JSON.stringify(hist));
  loadCashUpHistory();
  setSt('cuSt','Cash-up saved','ok');
  toast('Cash-up saved');
}

function loadCashUpHistory(){
  if(!curBranch)return;
  const key='evh_cu_'+curBranch.id;
  const hist=JSON.parse(localStorage.getItem(key)||'[]');
  const el=document.getElementById('cuHistory');
  if(!hist.length){el.innerHTML='<p style="font-size:13px;color:var(--mu)">No records yet for this branch.</p>';return;}
  el.innerHTML=hist.slice(0,15).map(r=>{
    const abs=Math.abs(r.variance);
    const ok=abs<=50;
    const over=r.variance>50;
    const col=ok?'var(--grn)':over?'#E0A840':'var(--red)';
    const lbl=ok?'Balanced':(over?`+R${abs.toFixed(0)}`:`−R${abs.toFixed(0)}`);
    return`<div class="cu-hist-row">
      <span class="cu-hist-date">${r.date}</span>
      <span class="cu-hist-actual">R${Number(r.actual).toFixed(0)} actual</span>
      <span class="cu-hist-var" style="color:${col}">${lbl}</span>
    </div>`;
  }).join('');
}

function saveTargets(){
  const val=parseFloat(document.getElementById('dailyTarget').value)||5000;
  localStorage.setItem('evh_daily_target',String(val));
  document.getElementById('targetSaved').style.display='block';
  setTimeout(()=>document.getElementById('targetSaved').style.display='none',2000);
  toast('Target saved');
  if(isHQ)buildCFODash();
}

/* ── Analysis modal ── */
let anlzTimer=null;
function showAnalysisModal(type,title,sub,actions){
  clearTimeout(anlzTimer);
  const m=document.getElementById('anlzModal');
  const c=document.getElementById('anlzCard');
  c.className='anlz-card '+type;
  document.getElementById('anlzIcon').textContent=type==='success'?'✓':'✕';
  document.getElementById('anlzTitle').textContent=title;
  document.getElementById('anlzSub').textContent=sub;
  const aa=document.getElementById('anlzActions');
  aa.innerHTML='';
  (actions||[]).forEach(a=>{
    const b=document.createElement('button');
    b.className='anlz-btn '+(a.primary?'primary':'ghost');
    b.textContent=a.label;
    b.onclick=()=>{closeAnlzModal();if(a.fn)a.fn();};
    aa.appendChild(b);
  });
  m.style.display='flex';
  anlzTimer=setTimeout(closeAnlzModal,type==='success'?5000:8000);
}
function closeAnlzModal(){
  clearTimeout(anlzTimer);
  document.getElementById('anlzModal').style.display='none';
}
/* ── Toast ── */
function toast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}
