/* ── Live Apps Script dashboard ── */
function fetchLiveJSONP(branch){
  return new Promise((resolve,reject)=>{
    if(!APPS_SCRIPT_URL){reject(new Error('Apps Script URL missing'));return;}
    const cb='evhLiveCb_'+Date.now()+'_'+Math.floor(Math.random()*10000);
    const script=document.createElement('script');
    const sep=APPS_SCRIPT_URL.includes('?')?'&':'?';
    window[cb]=(data)=>{delete window[cb];script.remove();resolve(data);};
    script.onerror=()=>{delete window[cb];script.remove();reject(new Error('Live dashboard failed'));};
    script.src=`${APPS_SCRIPT_URL}${sep}branch=${encodeURIComponent(branch)}&callback=${cb}&_=${Date.now()}`;
    document.body.appendChild(script);
  });
}
async function loadLiveDashboard(branch){
  try{
    const data=await fetchLiveJSONP(branch);
    if(!data||!data.ok)return;
    if(data.mode==='all'&&Array.isArray(data.branches)){
      data.branches.forEach(updateBDFromLive);
      buildHQDash();buildCFODash();
    }else if(data.dashboard){
      updateBDFromLive(data.dashboard);
      const b=BRANCHES.find(x=>x.id===data.dashboard.branch);
      if(b)buildBranchDash(b);
    }
  }catch(err){
    console.warn('Live dashboard unavailable:',err.message);
  }
}
function updateBDFromLive(d){
  if(!d||!d.branch||!BD[d.branch])return;
  BD[d.branch]={
    ...BD[d.branch],
    gross:Number(d.gross||0),
    cash:Number(d.cash||0),
    swipe:Number(d.eftSwipe||0),
    eft:Number(d.payflex||0),
    days:Number(d.days||0),
    bestDay:d.bestDay||BD[d.branch].bestDay||'—',
    bestAmt:Number(d.bestAmt||0)
  };
}

