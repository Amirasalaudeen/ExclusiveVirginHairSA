function requireMgmt(cb){
  if(sessionStorage.getItem('evh_mgmt')==='1'){cb();return;}
  mgmtCallback=cb;
  document.getElementById('mgmtGate').style.display='flex';
  setTimeout(()=>document.getElementById('mgmtCodeInp').focus(),80);
}

async function sha256(str){
  const buf=await crypto.subtle.digest('SHA-256',new TextEncoder().encode(str));
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

async function checkMgmtCode(){
  const val=document.getElementById('mgmtCodeInp').value.trim().toUpperCase();
  if(!val)return;
  const hash=await sha256(val);
  const expected=curGateBranch?BRANCH_HASHES[curGateBranch.id]:MGMT_HASH;
  const sessKey=curGateBranch?'evh_branch_'+curGateBranch.id:'evh_mgmt';
  if(hash===expected){
    const f=mgmtCallback;
    sessionStorage.setItem(sessKey,'1');
    closeMgmtGate();
    if(f)f();
  }else{
    document.getElementById('mgmtErr').style.display='block';
    document.getElementById('mgmtCodeInp').value='';
    document.getElementById('mgmtCodeInp').focus();
    setTimeout(()=>document.getElementById('mgmtErr').style.display='none',2500);
  }
}

function closeMgmtGate(){
  document.getElementById('mgmtGate').style.display='none';
  document.getElementById('mgmtCodeInp').value='';
  document.getElementById('mgmtErr').style.display='none';
  mgmtCallback=null;curGateBranch=null;
  document.getElementById('gateLogo').textContent='H';
  document.getElementById('gateTitle').textContent='Management Access';
