  return`<div class="card" style="padding:.75rem;margin-bottom:.75rem"><p style="font-size:11px;color:var(--mu);line-height:1.7">Branch KPIs for April 2026. Targets: R${target.toLocaleString()}/day revenue &middot; expense ratio &lt;20% &middot; 18+ trading days &middot; net margin &gt;75%. <span style="color:var(--grn)">&#9679;</span> on target &nbsp;<span style="color:#E0A840">&#9679;</span> watch &nbsp;<span style="color:var(--red)">&#9679;</span> action needed.</p></div><div class="tbl-wrap"><table class="kpi-table"><thead><tr><th>Branch</th><th>Rev/Day</th><th>Exp%</th><th>Days</th><th>Net%</th></tr></thead><tbody>${rows}</tbody></table></div>`;
