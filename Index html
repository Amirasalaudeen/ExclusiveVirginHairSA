    return`<tr><td style="font-size:13px;font-weight:500">${b.name}</td><td><span class="kpi-val"><span class="rag ${rAvg}"></span>R${avg.toLocaleString()}</span></td><td><span class="rag ${rExp}"></span>${expR}%</td><td><span class="rag ${rDays}"></span>${d.days}</td><td><span class="rag ${rNet}"></span>${netM}%</td></tr>`;
