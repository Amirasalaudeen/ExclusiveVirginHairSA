  (d.transactions||[]).forEach(t=>{
    const tr=document.createElement('tr');
    tr.innerHTML=`<td>${t.time||'—'}</td><td style="max-width:150px">${t.service}</td><td>${t.client_name||'—'}</td><td>${pBadge(t.payment_method)}</td><td>${rc(t.cash)}</td><td>${rc(t.swipe)}</td><td>${rc(t.eft_payflex_pjn)}</td><td style="font-weight:500;color:var(--gold-l)">${rc(t.total)}</td>`;
    tb.appendChild(tr);
  });
  const tot=document.createElement('tr');tot.className='row-total';
  tot.innerHTML=`<td colspan="4">DAILY TOTAL — ${d.date}</td><td>${rc(dt.cash)}</td><td>${rc(dt.swipe)}</td><td>${rc(dt.eft_payflex_pjn)}</td><td>${rc(dt.gross)}</td>`;
  tb.appendChild(tot);
  const eb=document.getElementById('expBlock'),el=document.getElementById('expList');
  el.innerHTML='';
  if(d.expenses&&d.expenses.length>0){
    eb.style.display='block';
    d.expenses.forEach(e=>el.innerHTML+=`<div class="exp-item"><span class="lbl">${e.description}</span><span class="amt">R${Number(e.amount).toFixed(0)}</span></div>`);
    el.innerHTML+=`<div class="exp-item ttl"><span class="lbl">Total expenses</span><span class="amt">R${Number(dt.total_expenses||0).toFixed(0)}</span></div>`;
  }else{eb.style.display='none';}
  document.getElementById('resSec').style.display='block';
  const txCount=(d.transactions||[]).length;
  document.getElementById('ascTitle').textContent=`✓ Analysis complete — ${txCount} transaction${txCount!==1?'s':''} found`;
  document.getElementById('ascSub').textContent=`${d.date} · Revenue R${Number(d.daily_total.gross).toFixed(0)} · verify below before saving`;
  document.getElementById('ascBanner').style.display='flex';
  buildSheetPreview(d);
  document.getElementById('sheetPreviewSec').style.display='block';
  document.getElementById('sheetSt').innerHTML='';
