/* ── Sheet export ── */
function buildTSV(d){
  if(!d)return'';
  const dt=d.daily_total,rows=[];
  rows.push([d.date,'','','','','','','','','',''].join('\t'));
  (d.transactions||[]).forEach(t=>rows.push([d.date,t.time||'',t.service,t.client_name||'',t.client_phone||'',t.payment_method,t.cash||'',t.swipe||'',t.eft_payflex_pjn||'',t.total||'',t.notes||''].join('\t')));
  const np=[];
  if(dt.cash)np.push(`Cash:R${dt.cash}`);
  if(dt.swipe)np.push(`Swipe:R${dt.swipe}`);
  if(dt.eft_payflex_pjn)np.push(`EFT:R${dt.eft_payflex_pjn}`);
  rows.push([d.date,'TOTAL',`DAILY TOTAL - ${d.date}`,'','','',dt.cash||'',dt.swipe||'',dt.eft_payflex_pjn||'',dt.gross||'',np.join(' | ')].join('\t'));
  (d.expenses||[]).forEach(e=>rows.push([d.date,'EXPENSE',e.description,'','','','','','',e.amount,'Expense'].join('\t')));
  return rows.join('\n');
}

